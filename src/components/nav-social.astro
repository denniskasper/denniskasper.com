---
const { icon, link } = Astro.props

const labels: Record<string, string> = {
  github: 'GitHub profile (opens in new tab)',
  linkedin: 'LinkedIn profile (opens in new tab)',
}
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={labels[icon] || `${icon} (opens in new tab)`}
  class="group p-2.5 rounded-full hover:bg-dark/5 dark:hover:bg-light/5 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-light dark:focus-visible:ring-offset-dark"
>
  <img
    src={`/icons/${icon}.svg`}
    alt=""
    class="h-5 w-5 cursor-pointer opacity-50 group-hover:opacity-100 transition-opacity duration-300 dark:invert"
  />
</a>
