---
import Layout from '@layouts/layout.astro'
---

<Layout title="404 | Dennis Kasper">
  <div class="flex flex-col items-center justify-center pt-24 md:pt-32 text-center">
    <h1 class="font-display text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-bold text-accent/20 mb-4 animate-fade-up stagger-1">404</h1>
    <p class="text-lg text-muted-light dark:text-muted-dark mb-8 animate-fade-up stagger-2">
      This page drifted away.
    </p>
    <a
      href="/"
      class="text-sm font-medium tracking-wide uppercase text-accent hover:text-accent-muted transition-colors duration-300 animate-fade-up stagger-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-light dark:focus-visible:ring-offset-dark rounded-sm"
    >
      Back to shore
    </a>
  </div>
</Layout>
