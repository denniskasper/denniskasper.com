---
import NavLink from '@components/nav-link.astro'
import NavSocial from '@components/nav-social.astro'

export interface Props {
  title?: string
  frontmatter?: {
    title?: string
  }
}

const { title } = Astro.props as Props
const pageTitle = title || Astro.props.frontmatter?.title

const year = new Date().getFullYear()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <link
      rel="icon"
      href="/favicon.svg"
      type="image/svg+xml"
    />
    <title>{pageTitle}</title>
    <meta name="description" content="Dennis Kasper - Software engineer building full-stack software in the automotive industry, from cloud infrastructure to data platforms." />
    <meta name="theme-color" content="#f0ece4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111110" media="(prefers-color-scheme: dark)" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content="Engineer with a passion for solving problems and windsurfing. Building full-stack software in the automotive industry." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://denniskasper.com" />
    <link
      rel="stylesheet"
      href="/styles/global.css"
    />
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('denniskasper.com-theme')
        if (saved === 'dark') document.documentElement.classList.add('dark')
      })()
    </script>
  </head>
  <body class="bg-light dark:bg-dark text-dark dark:text-light font-body text-base leading-relaxed antialiased">
    <div class="min-h-screen flex flex-col">
      <main class="w-full max-w-3xl mx-auto px-4 sm:px-6 md:px-8 flex-1 pb-24 sm:pb-0">
        <header class="flex items-center justify-between pt-8 pb-12 sm:pt-10 sm:pb-16 md:pt-14 md:pb-20 animate-fade-in">
          <nav class="flex items-center gap-x-4 sm:gap-x-6 md:gap-x-8">
            <NavLink
              title="home"
              url="/"
            />
            <NavLink
              title="resume"
              url="/resume/"
            />
          </nav>
          <nav class="flex items-center gap-x-3">
            <NavSocial
              icon="github"
              link="https://github.com/denniskasper"
            />
            <NavSocial
              icon="linkedin"
              link="https://www.linkedin.com/in/dennis-kasper-995b2112b"
            />
            <button
              data-icon-btn
              class="ml-3 p-2.5 rounded-full hover:bg-dark/5 dark:hover:bg-light/5 transition-colors duration-300 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-light dark:focus-visible:ring-offset-dark"
              aria-label="Toggle theme"
            >
              <img
                data-icon
                src="/icons/moon.svg"
                alt="Toggle theme"
                class="h-5 w-5"
              />
            </button>
          </nav>
        </header>
        <article>
          <slot />
        </article>
      </main>

      <footer class="w-full max-w-3xl mx-auto px-4 sm:px-6 md:px-8 py-12 mt-20">
        <div class="flex items-center justify-between text-sm text-muted-light dark:text-muted-dark">
          <span>&copy; {year} Dennis Kasper</span>
          <span class="flex items-center gap-1.5">
            made with <span class="text-red-500">&#10084;</span>
          </span>
        </div>
      </footer>

      <dialog
        data-banner
        role="alertdialog"
        aria-label="Storage consent"
        class="fixed bottom-0 left-0 right-0 z-50 border-none bg-transparent p-0"
      >
        <div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-8 pb-6">
          <div class="bg-surface-light dark:bg-surface-dark border border-dark/10 dark:border-light/10 rounded-xl px-6 py-5 shadow-lg backdrop-blur-sm">
            <p class="text-sm mb-4 text-muted-light dark:text-muted-dark">
              This site uses local storage to remember your theme preference.
            </p>
            <div class="flex gap-3">
              <button
                data-acceptButton
                class="px-4 py-2.5 text-sm font-medium bg-accent text-dark rounded-lg hover:bg-accent-muted transition-colors duration-300 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface-light dark:focus-visible:ring-offset-surface-dark"
              >
                Accept
              </button>
              <button
                data-declineButton
                class="px-4 py-2.5 text-sm font-medium text-muted-light dark:text-muted-dark hover:text-dark dark:hover:text-light rounded-lg transition-colors duration-300 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface-light dark:focus-visible:ring-offset-surface-dark"
              >
                Decline
              </button>
            </div>
          </div>
        </div>
      </dialog>
    </div>
  </body>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const localStorageAccept = 'denniskasper.com-storageAccepted'
      const localStorageTheme = 'denniskasper.com-theme'

      const iconSunSource = '/icons/sun.svg'

      let currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light'

      const banner = document.querySelector('[data-banner]') as HTMLDialogElement
      const acceptButton = document.querySelector('[data-acceptButton]') as HTMLButtonElement
      const declineButton = document.querySelector('[data-declineButton]') as HTMLButtonElement
      const icon = document.querySelector('[data-icon]') as HTMLImageElement

      const storageAccepted = localStorage.getItem(localStorageAccept)

      if (storageAccepted === null) {
        banner.show()
      }

      acceptButton.addEventListener('click', () => {
        localStorage.setItem(localStorageAccept, 'true')
        banner.close()

        localStorage.setItem(localStorageTheme, currentTheme)
      })

      declineButton.addEventListener('click', () => {
        banner.close()
        localStorage.setItem(localStorageAccept, 'false')
      })

      // Sync icon to match theme already applied by head script
      if (currentTheme === 'dark') {
        icon.src = iconSunSource
      }

      icon?.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark')

        const storageAccepted = localStorage.getItem(localStorageAccept)

        if (document.documentElement.classList.contains('dark')) {
          icon.src = iconSunSource
          currentTheme = 'dark'

          if (storageAccepted === 'true') {
            localStorage.setItem(localStorageTheme, 'dark')
          }
        } else {
          icon.src = '/icons/moon.svg'
          currentTheme = 'light'

          if (storageAccepted === 'true') {
            localStorage.setItem(localStorageTheme, 'light')
          }
        }
      })
    })
  </script>
</html>
